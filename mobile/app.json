{
  "expo": {
    "name": "CloudCode",
    "slug": "cloudcode",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cloudcode.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.cloudcode.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "cloudcode",
    "plugins": [
      "./plugins/withExcludeSupport",
      "expo-router",
      "expo-secure-store",
      [
        "@sentry/react-native",
        {
          "organization": "cloudcode-ja",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f53068f-8be7-48fa-98e0-fc12c43923b5"
      }
    }
  }
}
